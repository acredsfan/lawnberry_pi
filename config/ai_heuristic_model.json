{
  "model_name": "baseline-color-detector",
  "model_format": "custom",
  "version": "1.0",
  "task": "obstacle_detection",
  "input_width": 224,
  "input_height": 224,
  "class_labels": ["obstacle"],
  "rules": [
    {
      "class_name": "obstacle",
      "min_rgb": [180, 0, 0],
      "max_rgb": [255, 140, 140],
      "min_area_ratio": 0.01,
      "max_components": 6
    }
  ]
}
