# The external high-gain radio must not enter USB autosuspend.
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="2357", ATTR{idProduct}=="0138", TEST=="power/control", ATTR{power/control}="on"
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="2357", ATTR{idProduct}=="0138", TEST=="power/autosuspend_delay_ms", ATTR{power/autosuspend_delay_ms}="-1"
