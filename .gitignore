# =============================================================
# LawnBerry Pi — .gitignore
# =============================================================

# Specify AI agent directory (track constitution/templates, ignore output)
.specify/out/
.specify/scripts/__pycache__/

# =============================================================
# Python
# =============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.pyi
.Python

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
lawnberry_pi.egg-info/
.installed.cfg
*.egg
MANIFEST

# =============================================================
# Virtual environments
# =============================================================
.venv/
venv/
ENV/
env/
.virtualenv/
venv-coral/

# =============================================================
# Testing & coverage
# =============================================================
.pytest_cache/
.coverage
.coverage.*
.tox/
.nox/
htmlcov/
nosetests.xml
coverage.xml
*.cover
.hypothesis/
pytestdebug.log
.cache/
.mypy_cache/
.dmypy.json
dmypy.json

# =============================================================
# Database files
# =============================================================
*.db
*.sqlite
*.sqlite3
data/*.sqlite3
data/*.db
data/lawnberry.db
data/lawnberry.db-journal

# =============================================================
# Logs
# =============================================================
logs/
*.log
*.log.*
backend.log
frontend.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# =============================================================
# Runtime / generated data
# =============================================================
data/*.json
data/*.csv
data/exports/
memory/*.json

# =============================================================
# Process files
# =============================================================
*.pid
*.seed
*.pid.lock

# =============================================================
# Frontend (Node.js / Vue)
# =============================================================
node_modules/
.npm
.yarn/
.pnp.*
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/dist-ssr/
*.local

# =============================================================
# IDEs and editors
# =============================================================
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# =============================================================
# OS files
# =============================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# =============================================================
