# =============================================================
.env
.env.local
.env.*.local
.env.production
config/secrets.json
config/maps_settings.json
config/*.key
config/*.pem

# =============================================================
# Temporary files
# =============================================================
tmp/
temp/
*.tmp
*.temp
*.bak
.temp/

# =============================================================
# Backups
# =============================================================
backups/
*.backup

# =============================================================
# Verification artifacts (Specify agent runtime records)
# =============================================================
verification_artifacts/

# =============================================================
# Build artifacts
# =============================================================
*.tar.gz
*.zip

# =============================================================
# Hardware integration (local testing only)
# =============================================================
hw-integration/
robohat-rp2040-code/*.uf2

# uv.lock is intentionally tracked for reproducible dependency pinning on the Pi

